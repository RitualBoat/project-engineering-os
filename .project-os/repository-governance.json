{
  "schemaVersion": 1,
  "defaultBranch": "main",
  "project": {
    "title": "Project Engineering OS",
    "statuses": [
      "Backlog",
      "Ready",
      "In progress",
      "In review",
      "Blocked",
      "Done"
    ]
  },
  "labels": [
    "bug",
    "change",
    "documentation",
    "debt-remediation",
    "security",
    "incident",
    "rollback"
  ],
  "ruleset": {
    "requiresPullRequest": true,
    "requiredApprovals": 0,
    "requiresCodeOwnerReview": false,
    "requiresConversationResolution": true,
    "requiredChecks": [
      "CI / required"
    ],
    "blocksForcePush": true,
    "blocksDeletion": true
  },
  "tags": {
    "pattern": "v*",
    "restrictedToReleaseWorkflow": true
  },
  "releaseEnvironment": {
    "name": "npm-publish",
    "requiredReviewers": 1,
    "trustedPublisher": {
      "provider": "npm",
      "workflow": ".github/workflows/release.yml"
    }
  },
  "manualGates": [
    "repository creation",
    "ruleset activation",
    "environment reviewer",
    "npm trusted publisher",
    "first release approval"
  ]
}
