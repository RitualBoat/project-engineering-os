{
  "schemaVersion": 1,
  "budget": {
    "threshold": 5,
    "minorUnits": 1,
    "escalatedMinorUnits": 2
  },
  "triggers": {
    "flowsWithResidualDebt": 5,
    "recurrenceFlows": 3
  },
  "github": {
    "mode": "required",
    "repo": "example/fixture-repo",
    "remediationLabel": "debt-remediation",
    "issueTitlePrefix": "[Debt][Saneamiento]"
  },
  "plans": [
    {
      "id": "plan-a",
      "title": "Plan A",
      "doc": "docs/plan-a.md"
    },
    {
      "id": "plan-b",
      "title": "Plan B",
      "doc": "docs/plan-b.md"
    }
  ],
  "planRouting": {
    "labelMap": {
      "feature-a": "plan-a",
      "feature-b": "plan-b"
    },
    "default": "plan-a"
  },
  "allowlistLabels": [
    "debt-remediation",
    "security",
    "incident",
    "rollback"
  ]
}
