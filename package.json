{
  "name": "create-project-engineering-os",
  "version": "0.1.1",
  "description": "Bootstrap, governance, SDD harness and technical-debt control for reproducible projects.",
  "keywords": [
    "agents",
    "bootstrap",
    "governance",
    "openspec",
    "sdd"
  ],
  "license": "MIT",
  "author": "RitualBoat contributors",
  "type": "module",
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  },
  "bin": {
    "create-project-engineering-os": "bin/project-os.mjs",
    "project-os": "bin/project-os.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./blueprint": "./src/blueprint.mjs",
    "./debt": "./src/debt/index.mjs",
    "./transactions": "./src/transaction.mjs"
  },
  "files": [
    "bin/",
    "blueprint/",
    "docs/",
    "schema/",
    "src/",
    "CHANGELOG.md",
    "LICENSE",
    "MANAGED_FILES_NOTICE.md",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RitualBoat/project-engineering-os.git"
  },
  "bugs": {
    "url": "https://github.com/RitualBoat/project-engineering-os/issues"
  },
  "homepage": "https://github.com/RitualBoat/project-engineering-os#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "ajv": "8.20.0"
  },
  "scripts": {
    "check": "npm run check:package && npm run check:neutrality && npm run check:docs && npm run check:workflows && npm test",
    "check:docs": "node ./scripts/check-docs.mjs",
    "check:neutrality": "node ./scripts/check-neutrality.mjs",
    "check:package": "node ./scripts/check-package.mjs",
    "check:workflows": "node ./scripts/check-workflows.mjs",
    "fixture": "node ./scripts/verify-fixture.mjs",
    "opsx-check": "node ./bin/project-os.mjs opsx-check --target .",
    "pack:verify": "node ./scripts/pack-release.mjs --dry-run",
    "release:pack": "node ./scripts/pack-release.mjs --output release",
    "release:verify": "node ./scripts/verify-release.mjs release",
    "test": "node --test"
  }
}
