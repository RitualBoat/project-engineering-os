{
  "schemaVersion": "1.0.0",
  "mode": "dry-run",
  "remoteMutationDuringBootstrap": false,
  "project": {
    "title": "Product OS",
    "description": "Operational source for discovery, technical decisions, active delivery waves, gates, and evidence.",
    "visibility": "private-until-owner-decides",
    "views": [
      "Current wave",
      "Readiness and blockers",
      "Evidence review"
    ]
  },
  "branchStrategy": {
    "status": "manual-pending",
    "defaultBranch": null,
    "changeBranches": null,
    "directPushToProtectedBranch": false,
    "closeThroughPullRequest": true
  },
  "labels": [
    {
      "name": "type:discovery",
      "color": "1D76DB",
      "description": "Product discovery and evidence."
    },
    {
      "name": "type:architecture",
      "color": "5319E7",
      "description": "Architecture decision or contract."
    },
    {
      "name": "type:quality",
      "color": "0E8A16",
      "description": "Quality strategy or evidence."
    },
    {
      "name": "type:infrastructure",
      "color": "006B75",
      "description": "Environment, delivery, or observability."
    },
    {
      "name": "type:change",
      "color": "FBCA04",
      "description": "Versioned implementation change."
    },
    {
      "name": "epic",
      "color": "3E4B9E",
      "description": "Outcome grouping with bounded waves."
    },
    {
      "name": "blocked",
      "color": "B60205",
      "description": "Cannot advance until a declared dependency or gate is resolved."
    }
  ],
  "statuses": [
    "Inbox",
    "Ready",
    "In progress",
    "In review",
    "Blocked",
    "Done"
  ],
  "fields": [
    {
      "name": "Owner",
      "type": "text"
    },
    {
      "name": "Stage",
      "type": "single-select",
      "options": [
        "Environment",
        "Discovery",
        "Technical profile",
        "Product start"
      ]
    },
    {
      "name": "Readiness",
      "type": "single-select",
      "options": [
        "Not assessed",
        "Ready",
        "Blocked",
        "Exception"
      ]
    },
    {
      "name": "Evidence",
      "type": "text"
    },
    {
      "name": "Priority",
      "type": "single-select",
      "options": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    {
      "name": "Size",
      "type": "single-select",
      "options": [
        "XS",
        "S",
        "M",
        "L",
        "XL"
      ]
    }
  ],
  "milestonePolicy": {
    "createAfterVisionApproval": true,
    "nameFromOutcomeNotImplementation": true
  },
  "milestones": [],
  "epicPolicy": {
    "oneOutcomePerEpic": true,
    "observableClosureCriteria": true,
    "waveDependenciesRequired": true
  },
  "issueActivation": {
    "activeWave": true,
    "nextWave": true,
    "laterWavesRemainInMasterPlan": true
  },
  "manualGates": [
    "Authenticate GitHub CLI or connector with approved scopes.",
    "Create or select the GitHub Project.",
    "Configure branch protection and required checks.",
    "Approve costs, licenses, and irreversible remote changes."
  ]
}
