{
  "schemaVersion": "1.0.0",
  "vocabulary": [
    "native",
    "generated",
    "documented",
    "unsupported"
  ],
  "definitions": {
    "native": "The harness consumes a dedicated repository surface.",
    "generated": "The constructor creates a deterministic adapter consumed through a supported general surface.",
    "documented": "The behavior remains visible in AGENTS.md but is not technically enforced by the harness.",
    "unsupported": "The harness cannot represent the capability and no equivalent enforcement is claimed."
  },
