{
  "schemaVersion": "1.0.0",
  "package": "@fission-ai/openspec",
  "version": "1.6.0",
  "nodeEngine": "^20.20.0 || >=22.22.0",
  "localOnly": true,
  "allowGlobalFallback": false,
  "allowFloatingInstall": false,
  "approvedInstallScripts": [
    "@fission-ai/openspec@1.6.0"
  ],
  "workflowOwner": "external-openspec",
  "workflowInitCommand": "npm exec --yes=false -- openspec init --tools codex,claude,cursor,github-copilot,opencode",
  "workflowUpdateCommand": "npm exec --yes=false -- openspec update",
  "workflowAdapterCommand": "npm run project-os:opsx:adapt",
  "workflowCheckCommand": "npm run project-os:opsx:check",
  "workflowCheckContract": ".project-os/openspec-ownership.md"
}
