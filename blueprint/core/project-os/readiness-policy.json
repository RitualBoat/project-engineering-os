{
  "schemaVersion": "1.0.0",
  "statusVocabulary": [
    "PASS",
    "FAIL",
    "EXCEPTION"
  ],
  "issueMarker": {
    "start": "<!-- project-os-readiness:pre-propose",
    "end": "project-os-readiness:pre-propose -->"
  },
  "projectMembership": {
    "required": true,
    "projectManifest": ".project-os/github/product-os.json",
    "projectTitlePointer": "/project/title",
    "unverifiedStatus": "FAIL",
    "exceptionField": "project-membership"
  },
  "phases": {
    "propose": {
      "requiredIssueState": "OPEN",
      "requiredSections": [
        "## Historia Original",
        "## Enriquecida"
      ],
      "requiredMetadataFields": [
        "schemaVersion",
        "change",
        "execution",
        "dependencies",
        "currentState",
        "scope",
        "observableCriteria",
        "owner",
        "risks",
        "surfaces",
        "manualInterventions",
        "costLicenseReview",
        "evidence",
        "rollback",
        "nonGoals",
        "exceptions"
      ],
      "requireDependenciesClosed": true,
      "remoteUnverifiedStatus": "FAIL"
    },
    "archive": {
      "changeRoot": "openspec/changes",
      "requiredFiles": [
        "proposal.md",
        "design.md",
        "tasks.md",
        "TLDR.md",
        "brownfield-baseline.md",
        "readiness.json"
      ],
      "requiredSpecPattern": "specs/*/spec.md",
      "requiredMetadataFields": [
        "schemaVersion",
        "issue",
        "change",
        "surfaces",
        "validations",
        "evidence",
        "rollback",
        "adversarialReview",
        "exceptions"
      ],
      "requiredValidationIds": [
        "openspec-strict"
      ],
      "requiredEvidenceIds": [
        "issue-link",
        "adversarial-review"
      ],
      "manualEvidenceIdsFromProfileCatalog": true,
      "requireTasksComplete": true,
      "requireIssueTraceability": true,
      "requireAdversarialReview": true,
      "remoteUnverifiedStatus": "FAIL"
    }
  },
  "exceptions": {
    "allowedFields": [
      "project-membership",
      "manual-evidence"
    ],
    "requiredFields": [
      "field",
      "reason",
      "owner",
      "approvedBy",
      "expiresOn",
      "recovery"
    ],
    "nonWaivable": [
      "issue-identity",
      "change-identity",
      "artifact-integrity",
      "tasks-complete",
      "secrets",
      "required-surface-evidence"
    ],
    "expirationFormat": "YYYY-MM-DD",
    "exceptionCountsAsPass": false
  },
