{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-engineering-os/debt-control/assessment",
  "title": "Assessment de cierre SDD (.project-os/debt/assessments/<flujo>.json)",
  "description": "Evidencia historica inmutable de un flujo. Todo cierre SDD produce uno, incluso clean. La validacion ejecutable vive en src/schema.mjs.",
  "type": "object",
  "required": ["schemaVersion", "flow", "date", "kind", "result", "candidates"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "flow": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "kind": { "enum": ["feature", "remediation", "baseline"] },
    "result": { "enum": ["clean", "debt"], "description": "debt exige al menos un candidato confirmado; clean exige cero." },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "artifact", "source", "category", "evidence", "verification"],
        "properties": {
          "title": { "type": "string" },
          "artifact": { "type": "string" },
          "source": { "type": "string", "description": "De donde salio el candidato: scanner, review, npm audit, log, nota historica." },
          "category": { "enum": ["defect", "technical-debt", "external-risk", "decision-required", "optional-improvement", "false-positive", "duplicate"] },
          "severity": { "enum": ["blocker", "major", "minor"] },
          "transversal": { "type": "boolean" },
          "critical": { "type": "boolean" },
          "planOwner": { "type": "string" },
          "consequence": { "type": "string" },
          "remediation": { "type": "string" },
          "resolvedPreviously": { "type": "boolean", "description": "Hallazgo historico verificado como ya corregido; no crea deuda." },
          "duplicateOf": { "type": "string", "pattern": "^debt-[0-9a-f]{12}$" },
          "evidence": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["type", "ref", "date"] } },
          "verification": {
            "type": "object",
            "required": ["method", "result", "date"],
            "description": "Obligatoria: ningun candidato entra al registro sin reproducirse, verificarse o justificarse."
          }
        }
      }
    },
    "resolves": { "type": "array", "items": { "type": "object", "required": ["id", "evidence"] } },
    "exceptions": { "type": "array", "items": { "type": "object", "required": ["id", "reason", "owner", "approvedBy", "expiresOn", "recovery"] } },
    "notes": { "type": "string" }
  }
}
