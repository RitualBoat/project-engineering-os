{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-os.local/schema/config.schema.json",
  "title": "Installed project constructor configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "stage",
    "codeIndexable",
    "activeProfiles",
    "harnesses",
    "githubMode",
    "branchStrategy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "stage": {
      "const": "environment-bootstrap"
    },
    "codeIndexable": {
      "const": false
    },
    "activeProfiles": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "documentation",
          "harness-tooling"
        ]
      }
    },
    "harnesses": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "codex",
          "claude-code",
          "cursor",
          "opencode",
          "github-copilot"
        ]
      }
    },
    "githubMode": {
      "enum": [
        "dry-run",
        "read-only"
      ]
    },
    "branchStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "defaultBranch",
        "protectedBranches",
        "changeBranchPrefix"
      ],
      "properties": {
        "status": {
          "const": "manual-pending"
        },
        "defaultBranch": {
          "type": "null"
        },
        "protectedBranches": {
          "type": "array",
          "maxItems": 0
        },
        "changeBranchPrefix": {
          "type": "null"
        }
      }
    }
  }
}
