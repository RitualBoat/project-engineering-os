{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-os.local/schema/pre-propose-readiness.schema.json",
  "title": "Project OS pre-propose readiness metadata v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "change",
    "execution",
    "dependencies",
    "currentState",
    "scope",
    "observableCriteria",
    "owner",
    "risks",
    "surfaces",
    "manualInterventions",
    "costLicenseReview",
    "evidence",
    "rollback",
    "nonGoals",
    "exceptions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "change": {
      "$ref": "#/$defs/change"
    },
    "execution": {
      "const": "versioned"
    },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "currentState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "sources"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "sources": {
          "$ref": "#/$defs/nonEmptyStrings"
        }
      }
    },
    "scope": {
      "$ref": "#/$defs/nonEmptyStrings"
    },
    "observableCriteria": {
      "$ref": "#/$defs/nonEmptyStrings"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "risks": {
      "$ref": "#/$defs/nonEmptyStrings"
    },
    "surfaces": {
      "$ref": "#/$defs/surfaces"
    },
    "manualInterventions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/manualIntervention"
      }
    },
    "costLicenseReview": {
      "$ref": "#/$defs/costLicenseReview"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automatic",
        "manual"
      ],
      "properties": {
        "automatic": {
          "$ref": "#/$defs/nonEmptyStrings"
        },
        "manual": {
          "$ref": "#/$defs/nonEmptyStrings"
        }
      }
    },
    "rollback": {
      "$ref": "#/$defs/rollbackPlan"
    },
    "nonGoals": {
      "$ref": "#/$defs/nonEmptyStrings"
    },
    "exceptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/exception"
      }
    }
  },
  "$defs": {
    "change": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "ai",
          "auth-security",
          "backend-api",
          "data-migration-sync",
          "documentation",
          "harness-tooling",
          "infra-deploy",
          "library-cli",
          "ui"
        ]
      }
    },
    "manualIntervention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "reason",
        "owner",
        "status",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "pending",
            "approved",
            "not-applicable"
          ]
        },
        "evidence": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "approved"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "costLicenseReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "owner",
        "evidence",
        "justification"
      ],
      "properties": {
        "status": {
          "enum": [
            "pending",
            "approved",
            "not-applicable"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "justification": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "approved"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "rollbackPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "trigger",
        "recovery"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "recovery": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "exception": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "reason",
        "owner",
        "approvedBy",
        "expiresOn",
        "recovery"
      ],
      "properties": {
        "field": {
          "enum": [
            "project-membership",
            "manual-evidence"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "approvedBy": {
          "type": "string",
          "minLength": 1
        },
        "expiresOn": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "recovery": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
