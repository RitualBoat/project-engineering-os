{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-os.local/schema/doctor-result.schema.json",
  "title": "Project constructor doctor result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "verdict",
    "counts",
    "results"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "PASS",
        "FAIL",
        "WARN",
        "SKIP"
      ],
      "properties": {
        "PASS": {
          "type": "integer",
          "minimum": 0
        },
        "FAIL": {
          "type": "integer",
          "minimum": 0
        },
        "WARN": {
          "type": "integer",
          "minimum": 0
        },
        "SKIP": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "profile",
          "status",
          "summary",
          "cause",
          "remediation",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "WARN",
              "SKIP"
            ]
          },
          "summary": {
            "type": "string"
          },
          "cause": {
            "type": "string"
          },
          "remediation": {
            "type": "string"
          },
          "evidence": {
            "type": "object"
          }
        }
      }
    }
  }
}
