{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-os.local/schema/harness-capabilities.schema.json",
  "title": "Project OS harness capability matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "vocabulary",
    "definitions",
    "harnesses",
    "parityPolicy"
  ],
  "properties": {
    "schemaVersion": {
      "$ref": "#/$defs/semver"
    },
    "vocabulary": {
      "const": [
        "native",
        "generated",
        "documented",
        "unsupported"
      ]
    },
    "definitions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "native",
        "generated",
        "documented",
        "unsupported"
      ],
      "properties": {
        "native": {
          "type": "string",
          "minLength": 1
        },
        "generated": {
          "type": "string",
          "minLength": 1
        },
        "documented": {
          "type": "string",
          "minLength": 1
        },
        "unsupported": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "harnesses": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/harness"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "claude-code"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/harness"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "codex"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/harness"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "cursor"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/harness"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "github-copilot"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/harness"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "opencode"
                }
              }
            }
          ]
        }
      ],
      "items": false
    },
    "parityPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missingDegradationIsFailure",
        "unsupportedNeverCountsAsNative",
        "configurationNeverProvesRuntime"
      ],
      "properties": {
        "missingDegradationIsFailure": {
          "const": true
        },
        "unsupportedNeverCountsAsNative": {
          "const": true
        },
        "configurationNeverProvesRuntime": {
          "const": true
        }
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support",
        "target",
        "owner",
        "validation"
      ],
      "properties": {
        "support": {
          "enum": [
            "native",
            "generated",
            "documented",
            "unsupported"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "owner": {
          "enum": [
            "constructor",
            "human-overlay",
            "external-openspec",
            "project"
          ]
        },
        "validation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instructions",
        "pathRules",
        "skills",
        "permissions",
        "mcp",
        "profiles"
      ],
      "properties": {
        "instructions": {
          "$ref": "#/$defs/capability"
        },
        "pathRules": {
          "$ref": "#/$defs/capability"
        },
        "skills": {
          "$ref": "#/$defs/capability"
        },
        "permissions": {
          "$ref": "#/$defs/capability"
        },
        "mcp": {
          "$ref": "#/$defs/capability"
        },
        "profiles": {
          "$ref": "#/$defs/capability"
        }
      }
    },
    "harness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "capabilities"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "$ref": "#/$defs/capabilities"
        }
      }
    }
  }
}
