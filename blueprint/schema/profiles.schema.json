{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-os.local/schema/profiles.schema.json",
  "title": "Project OS evidence profiles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "active",
    "profiles",
    "activationPolicy"
  ],
  "properties": {
    "schemaVersion": {
      "$ref": "#/$defs/semver"
    },
    "active": {
      "const": [
        "documentation",
        "harness-tooling"
      ]
    },
    "profiles": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/profile"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "ai"
                },
                "active": {
                  "const": false
                },
                "conditionalSignals": false
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profile"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "auth-security"
                },
                "active": {
                  "const": false
                },
                "conditionalSignals": false
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profile"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "backend-api"
                },
                "active": {
                  "const": false
                },
                "conditionalSignals": false
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profile"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "data-migration-sync"
                },
                "active": {
                  "const": false
                },
                "conditionalSignals": false
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profile"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "documentation"
                },
                "active": {
                  "const": true
                },
                "conditionalSignals": false
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profile"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "harness-tooling"
                },
                "active": {
                  "const": true
                },
                "conditionalSignals": false
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profile"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "infra-deploy"
                },
                "active": {
                  "const": false
                },
                "conditionalSignals": false
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profile"
            },
            {
              "type": "object",
              "properties": {
                "id": {
                  "const": "library-cli"
                },
                "active": {
                  "const": false
                },
                "conditionalSignals": false
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profile"
            },
            {
              "type": "object",
              "required": [
                "conditionalSignals"
              ],
              "properties": {
                "id": {
                  "const": "ui"
                },
                "active": {
                  "const": false
                },
                "conditionalSignals": {
                  "type": "array"
                }
              }
            }
          ]
        }
      ],
      "items": false
    },
    "activationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implicitActivation",
        "toolPresenceDoesNotActivateProfile",
        "decisionArtifactRequiredForConditionalProfiles",
        "naRequiresDeclaredConditionAndJustification"
      ],
      "properties": {
        "implicitActivation": {
          "const": false
        },
        "toolPresenceDoesNotActivateProfile": {
          "const": true
        },
        "decisionArtifactRequiredForConditionalProfiles": {
          "const": true
        },
        "naRequiresDeclaredConditionAndJustification": {
          "const": true
        }
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "conditionalSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "condition"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "condition": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "active",
        "activationRequires",
        "automaticValidations",
        "manualEvidence",
        "negativeCases",
        "rollback",
        "naConditions",
        "closureGate"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "active": {
          "type": "boolean"
        },
        "activationRequires": {
          "type": "string",
          "minLength": 1
        },
        "automaticValidations": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "manualEvidence": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "negativeCases": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        },
        "naConditions": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "closureGate": {
          "type": "string",
          "minLength": 1
        },
        "conditionalSignals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/conditionalSignal"
          }
        }
      }
    }
  }
}
